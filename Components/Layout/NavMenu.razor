@implements IDisposable
@using System.Security.Claims
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider
<nav class="ig-nav">
    <a class="ig-logo" href="/feed" aria-label="Home">Instagram</a>

    <AuthorizeView>
        <Authorized>
            <NavLink class="ig-nav-link" href="feed" Match="NavLinkMatch.Prefix">
                <span class="ig-nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M9.005 16.545a2.997 2.997 0 0 1 2.997-2.997h0A2.997 2.997 0 0 1 15 16.545V21h7V11.543L12 4 2 11.543V21h7.005Z"/></svg></span>
                <span class="ig-nav-label">Home</span>
            </NavLink>
            <NavLink class="ig-nav-link" href="explore">
                <span class="ig-nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg></span>
                <span class="ig-nav-label">Explore</span>
            </NavLink>
            <NavLink class="ig-nav-link" href="trending">
                <span class="ig-nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/></svg></span>
                <span class="ig-nav-label">Trending</span>
            </NavLink>
            <NavLink class="ig-nav-link" href="create">
                <span class="ig-nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="4"/><path d="M12 8v8M8 12h8"/></svg></span>
                <span class="ig-nav-label">Create</span>
            </NavLink>
            <NavLink class="ig-nav-link" href="stories/create">
                <span class="ig-nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="8"/><path d="M12 8v8M8 12h8"/></svg></span>
                <span class="ig-nav-label">Story</span>
            </NavLink>
            <NavLink class="ig-nav-link" href="saved">
                <span class="ig-nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 3h12a1 1 0 0 1 1 1v17l-7-4-7 4V4a1 1 0 0 1 1-1Z"/></svg></span>
                <span class="ig-nav-label">Saved</span>
            </NavLink>
            <NavLink class="ig-nav-link" href="follow-requests">
                <span class="ig-nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 11c1.7 0 3-1.3 3-3s-1.3-3-3-3-3 1.3-3 3 1.3 3 3 3Z"/><path d="M8 13c2.2 0 4-1.8 4-4S10.2 5 8 5 4 6.8 4 9s1.8 4 4 4Z"/><path d="M2 21c0-3.2 2.7-6 6-6s6 2.8 6 6"/><path d="M17 14v6M14 17h6"/></svg></span>
                <span class="ig-nav-label">Requests</span>
            </NavLink>
            <NavLink class="ig-nav-link" href="messages">
                <span class="ig-nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg></span>
                <span class="ig-nav-label">Messages</span>
            </NavLink>
            <NotificationBadge />
            @if (!string.IsNullOrEmpty(profileUserName))
            {
                <NavLink class="ig-nav-link" href="@($"profile/{profileUserName}")">
                    <span class="ig-nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-6 8-6s8 2 8 6"/></svg></span>
                    <span class="ig-nav-label">Profile</span>
                </NavLink>
            }
            <div class="ig-nav-spacer"></div>
            <form action="Account/Logout" method="post" class="ig-logout-form">
                <AntiforgeryToken />
                <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                <button type="submit" class="ig-nav-link ig-nav-button">
                    <span class="ig-nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9"/></svg></span>
                    <span class="ig-nav-label">Log out</span>
                </button>
            </form>
        </Authorized>
        <NotAuthorized>
            <NavLink class="ig-nav-link" href="Account/Login">
                <span class="ig-nav-label">Log in</span>
            </NavLink>
            <NavLink class="ig-nav-link ig-nav-link-primary" href="Account/Register">
                <span class="ig-nav-label">Sign up</span>
            </NavLink>
        </NotAuthorized>
    </AuthorizeView>
</nav>

@code {
    private string? currentUrl;
    private string? profileUserName;

    protected override async Task OnInitializedAsync()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;

        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        if (auth.User.Identity?.IsAuthenticated == true)
        {
            profileUserName = auth.User.Identity?.Name
                ?? auth.User.FindFirstValue(ClaimTypes.Name);
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
